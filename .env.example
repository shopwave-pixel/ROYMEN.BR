# ===================================================================
# ROY MEN - UNIFIED PRODUCTION & DEVELOPMENT CONFIGURATION
# ===================================================================
# Documented below are all standard and advanced setting keys required
# to run the full-stack server. Never commit your secrets to source control.

# -------------------------------------------------------------------
# SERVER PROFILE SETUP
# -------------------------------------------------------------------
# Set "production" on host environments. Default Port is 3000 for server.ts
NODE_ENV="production"
PORT=3000

# -------------------------------------------------------------------
# SECURE DATABASE GATEWAY (MONGODB ATLAS)
# -------------------------------------------------------------------
# Create a free cluster on MongoDB Atlas and paste your connection link:
MONGO_URI="mongodb+srv://<username>:<password>@<cluster-domain>/royman_production?retryWrites=true&w=majority"

# -------------------------------------------------------------------
# CRYPTOGRAPHIC SECURITY (JWT LOGINS)
# -------------------------------------------------------------------
# Generate a highly resilient random key for secure web token authentication signing.
JWT_SECRET="Generate_A_Long_Crypto_Key_At_Least_64_Characters_Random"
JWT_LIFETIME="30d"

# -------------------------------------------------------------------
# NODEMAILER DISPATCH ENGINE (SMTP FOR SECURITY OTP)
# -------------------------------------------------------------------
# Insert SMTP host credentials for automated secure security alerts and OTP verification
SMTP_HOST="mail.roymen.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="security@roymen.com"
SMTP_PASS="Insert_Your_Secure_Business_Email_Password"

# -------------------------------------------------------------------
# ASSETS SHIELD (CLOUDINARY CLOUD STORAGE)
# -------------------------------------------------------------------
# Integrate Cloudinary storage for luxury user custom measurements uploads and assets cataloging
CLOUDINARY_CLOUD_NAME="roy_men_bd"
CLOUDINARY_API_KEY="918347184712847"
CLOUDINARY_API_SECRET="Insert_Your_Cloudinary_Secret_Here"

# -------------------------------------------------------------------
# COUTURE CONTEXT ENGINE (GEMINI INTELLIGENT ADVISOR)
# -------------------------------------------------------------------
# Standard Gemini API Key for driving tailors recommendations models (Optionally active)
GEMINI_API_KEY="Insert_Your_Gemini_API_Token_Keys"

# -------------------------------------------------------------------
# CLIENT-SIDE VITE EXTRA OVERIDES (OPTIONAL)
# -------------------------------------------------------------------
# Only required if decoupling React front-end (hosted on Netlify) from Express backend API
# If serving unified stacked servers via server.ts, leave empty to default to relative pathing!
VITE_API_URL="https://roy-men-production.up.railway.app/api/v1"
CLIENT_ORIGIN="https://roymen-shop.netlify.app"
